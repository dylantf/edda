module RequestTest

import Std.BitString
import Std.Test (Testing, describe, test, assert_eq)
import Edda (
  Request,
  Method,
  POST,
  AcceptRange,
  EncodingRange,
  MultipartFileTooLarge,
  MultipartText,
  accept_encoding_ranges,
  accept_ranges,
  accepts_encoding,
  accepts,
  default_multipart_options,
  form_entries,
  form_values,
  form_get,
  form_get_all,
  query_values,
  cookies,
  cookie,
  multipart_values,
  multipart_values_with,
  multipart_get,
  multipart_file,
  preferred_content_encoding,
  preferred_content_type,
  sanitize_filename
)

fun req : Method -> String -> Request
req method path = Request {
  method: method,
  path: path,
  original_path: path,
  query: Nothing,
  matches: [],
  params: [],
  headers: [],
  body: Nothing,
}

fun with_query : String -> Request -> Request
with_query value request = { request | query: Just value }

fun with_header : String -> String -> Request -> Request
with_header name value request =
  { request | headers: request.headers <> [(name, value)] }

fun with_body : String -> Request -> Request
with_body value request =
  { request | body: Just (BitString.from_string value) }

fun multipart_req : String -> Request
multipart_req body =
  req POST "/upload"
    |> with_header "Content-Type" "multipart/form-data; boundary=\"abc\""
    |> with_body body

fun multipart_body : String
multipart_body = "--abc\r\n"
  <> "Content-Disposition: form-data; name=\"caption\"\r\n"
  <> "\r\n"
  <> "hello\r\n"
  <> "--abc\r\n"
  <> "Content-Disposition: form-data; name=\"upload\"; filename=\"semi; quote\\\" slash\\\\.txt\"\r\n"
  <> "Content-Type: text/plain\r\n"
  <> "\r\n"
  <> "bytes\r\n"
  <> "--abc--"

pub fun tests : Unit -> Unit needs {Testing}
tests () = {
  describe "Request helpers" (fun () -> {
    test "query_values decodes urlencoded values and preserves duplicates" (fun () -> {
      let result = query_values (req POST "/search" |> with_query "q=hello+world&tag=a&tag=b%21")
      case result {
        Ok values -> {
          assert_eq (form_entries values) [
            ("q", "hello world"),
            ("tag", "a"),
            ("tag", "b!"),
          ]
          assert_eq (form_get "q" values) (Just "hello world")
          assert_eq (form_get_all "tag" values) ["a", "b!"]
        }
        Err _ -> assert_eq True False
      }
    })

    test "form_values decodes application/x-www-form-urlencoded bodies" (fun () -> {
      let request =
        req POST "/form"
          |> with_header "Content-Type" "application/x-www-form-urlencoded; charset=utf-8"
          |> with_body "name=Alice+Smith&tags=demo&tags=forms"
      case form_values request {
        Ok values -> {
          assert_eq (form_get "name" values) (Just "Alice Smith")
          assert_eq (form_get_all "tags" values) ["demo", "forms"]
        }
        Err _ -> assert_eq True False
      }
    })

    test "cookies parses duplicate headers and percent escapes" (fun () -> {
      let request =
        req POST "/session"
          |> with_header "Cookie" "session=abc%20123; theme=light"
          |> with_header "Cookie" "theme=dark"
      assert_eq (cookies request) [
        ("session", "abc 123"),
        ("theme", "light"),
        ("theme", "dark"),
      ]
      assert_eq (cookie "session" request) (Just "abc 123")
    })

    test "missing Accept accepts any offered content type" (fun () -> {
      let request = req POST "/resource"
      assert_eq (accept_ranges request) [
        AcceptRange { media_type: "*/*", quality: 1000 },
      ]
      assert_eq (accepts "application/json" request) True
      assert_eq (preferred_content_type ["text/html", "application/json"] request) (Just "text/html")
    })

    test "accept_ranges parses q-values and quoted commas" (fun () -> {
      let request =
        req POST "/resource"
          |> with_header "Accept" "text/plain; note=\"a,b\"; q=0.4, application/json;q=0.75, image/png;q=0"
      assert_eq (accept_ranges request) [
        AcceptRange { media_type: "text/plain", quality: 400 },
        AcceptRange { media_type: "application/json", quality: 750 },
        AcceptRange { media_type: "image/png", quality: 0 },
      ]
    })

    test "preferred_content_type uses q-values before server order" (fun () -> {
      let request =
        req POST "/resource"
          |> with_header "Accept" "text/html;q=0.5, application/json;q=0.9"
      assert_eq (preferred_content_type ["text/html", "application/json"] request) (Just "application/json")
    })

    test "preferred_content_type uses specificity to break q ties" (fun () -> {
      let request =
        req POST "/resource"
          |> with_header "Accept" "application/*;q=0.8, application/json;q=0.8"
      assert_eq (preferred_content_type ["application/xml", "application/json"] request) (Just "application/json")
    })

    test "q=0 marks a content type unacceptable" (fun () -> {
      let request =
        req POST "/resource"
          |> with_header "Accept" "*/*;q=0, application/json;q=1"
      assert_eq (accepts "text/html" request) False
      assert_eq (accepts "application/json" request) True
      assert_eq (preferred_content_type ["text/html", "application/json"] request) (Just "application/json")
    })

    test "specific q=0 overrides Accept wildcards" (fun () -> {
      let request =
        req POST "/resource"
          |> with_header "Accept" "*/*;q=1, text/html;q=0"
      assert_eq (accepts "text/html" request) False
      assert_eq (accepts "application/json" request) True
    })

    test "missing Accept-Encoding accepts any offered encoding" (fun () -> {
      let request = req POST "/resource"
      assert_eq (accept_encoding_ranges request) [
        EncodingRange { encoding: "*", quality: 1000 },
      ]
      assert_eq (accepts_encoding "gzip" request) True
      assert_eq (preferred_content_encoding ["br", "gzip"] request) (Just "br")
    })

    test "Accept-Encoding parses q-values and chooses preferred encoding" (fun () -> {
      let request =
        req POST "/resource"
          |> with_header "Accept-Encoding" "gzip;q=0.5, br;q=1, zstd;q=0"
      assert_eq (accept_encoding_ranges request) [
        EncodingRange { encoding: "gzip", quality: 500 },
        EncodingRange { encoding: "br", quality: 1000 },
        EncodingRange { encoding: "zstd", quality: 0 },
      ]
      assert_eq (preferred_content_encoding ["gzip", "br"] request) (Just "br")
      assert_eq (accepts_encoding "zstd" request) False
    })

    test "identity encoding is acceptable unless excluded" (fun () -> {
      let request =
        req POST "/resource"
          |> with_header "Accept-Encoding" "gzip;q=1"
      assert_eq (accepts_encoding "identity" request) True
      assert_eq (preferred_content_encoding ["identity"] request) (Just "identity")
    })

    test "specific encoding q=0 overrides wildcard" (fun () -> {
      let request =
        req POST "/resource"
          |> with_header "Accept-Encoding" "*;q=1, gzip;q=0"
      assert_eq (accepts_encoding "gzip" request) False
      assert_eq (accepts_encoding "br" request) True
    })

    test "wildcard q=0 excludes implicit identity" (fun () -> {
      let request =
        req POST "/resource"
          |> with_header "Accept-Encoding" "gzip;q=1, *;q=0"
      assert_eq (accepts_encoding "identity" request) False
      assert_eq (preferred_content_encoding ["identity", "gzip"] request) (Just "gzip")
    })

    test "sanitize_filename preserves spaces but rejects path-like names" (fun () -> {
      assert_eq (sanitize_filename "Alice notes.txt") (Just "Alice notes.txt")
      assert_eq (sanitize_filename "") Nothing
      assert_eq (sanitize_filename ".") Nothing
      assert_eq (sanitize_filename "..") Nothing
      assert_eq (sanitize_filename "../secret.txt") Nothing
      assert_eq (sanitize_filename "dir\\secret.txt") Nothing
    })

    test "multipart_values parses quoted parameters and file parts" (fun () -> {
      case multipart_values (multipart_req multipart_body) {
        Ok values -> {
          case multipart_get "caption" values {
            Just (MultipartText value) -> assert_eq value "hello"
            _ -> assert_eq True False
          }
          case multipart_file "upload" values {
            Just file -> {
              assert_eq file.filename "semi; quote\" slash\\.txt"
              assert_eq file.content_type (Just "text/plain")
              assert_eq (BitString.to_string file.body) (Ok "bytes")
            }
            Nothing -> assert_eq True False
          }
        }
        Err _ -> assert_eq True False
      }
    })

    test "multipart_values_with enforces file byte limits" (fun () -> {
      let options = { default_multipart_options | max_file_bytes: Just 3 }
      let result = multipart_values_with options (multipart_req multipart_body)
      case result {
        Err (MultipartFileTooLarge name limit actual) -> {
          assert_eq name "upload"
          assert_eq limit 3
          assert_eq actual 5
        }
        _ -> assert_eq True False
      }
    })
  })
}
